{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "enabledManagers": ["github-actions", "npm"],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["^cloudnative-pg-timescaledb/versions\\.yaml$"],
      "matchStrings": ["cnpg_tag:\\s*(?<currentValue>standard-[^\\s]+)"],
      "depNameTemplate": "ghcr.io/cloudnative-pg/postgresql",
      "datasourceTemplate": "docker"
    }
  ],
  "ignorePaths": [
    "vendor/**",
    "cloudnative-pg-timescaledb/versions.yaml",
    "cloudnative-pg-timescaledb/generated/**"
  ]
}
